---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const faqs = [
  {
    q: 'What is Pakiza?',
    a: 'Pakiza is an Android app by HSR Utility offering a curated collection of HD Islamic wallpapers, status images, and ringtones & nasheeds — all free to use. It is designed specifically for the Muslim community.',
  },
  {
    q: 'When will Pakiza be available on the Play Store?',
    a: "Pakiza is currently in development and will be launching on the Google Play Store soon. Drop us an email at support@hsrutility.com and we'll notify you when it's live.",
  },
  {
    q: 'Is Pakiza free?',
    a: 'Yes. Core content — wallpapers, status images, ringtones, and nasheeds — is completely free to browse, save, and share.',
  },
  {
    q: 'How do I report a bug or request a feature?',
    a: 'Email us at support@hsrutility.com with the subject line "Bug Report — Pakiza" or "Feature Request — Pakiza". We read every email and reply within 48 hours.',
  },
  {
    q: 'How do I delete my account and data?',
    a: 'You can request permanent deletion of your account and data at any time. Visit our Delete My Account page for full step-by-step instructions.',
    link: { label: 'Go to Delete My Account', href: '/delete-account' },
  },
  {
    q: 'Which Android versions does Pakiza support?',
    a: 'Pakiza supports Android 7.0 (Nougat) and above. We recommend keeping your device updated for the best experience.',
  },
];
---

<Layout
  title="Support"
  description="HSR Utility Support — Find answers to common questions about Pakiza, or get in touch with our team."
>
  <Navbar />

  <main class="pt-36 pb-24 px-6">
    <div class="max-w-3xl mx-auto">

      <!-- Header -->
      <div class="text-center mb-16 reveal">
        <h1 class="font-serif text-4xl md:text-6xl font-bold text-white leading-tight mb-4">
          Help &amp; <em class="text-gold-400 not-italic">Support</em>
        </h1>
        <p class="text-slate-400 text-lg max-w-md mx-auto">
          Find quick answers to common questions, or reach out — we reply within 48 hours.
        </p>
      </div>

      <!-- Account Deletion card -->
      <div class="reveal glass-card rounded-2xl p-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-14">
        <div>
          <span class="inline-block text-[10px] font-semibold tracking-[0.18em] uppercase text-gold-500 bg-gold-500/10 px-3 py-1 rounded-full mb-2">
            Account &amp; Data
          </span>
          <h2 class="text-white font-semibold text-lg">Request account &amp; data deletion</h2>
          <p class="text-slate-400 text-sm mt-1">Permanently delete your Pakiza account and associated data at any time.</p>
        </div>
        <a
          href="/delete-account"
          class="flex-shrink-0 border border-white/20 text-white text-sm px-5 py-2.5 rounded-full hover:border-white/40 hover:bg-white/5 transition-all duration-200 whitespace-nowrap"
        >
          Delete Account →
        </a>
      </div>

      <!-- FAQ -->
      <div class="reveal mb-16">
        <h2 class="font-serif text-2xl font-bold text-white mb-8">Frequently Asked Questions</h2>

        <div id="faq-list" class="divide-y divide-white/5">
          {faqs.map((faq, i) => (
            <div class="faq-item py-1">
              <button
                class="faq-trigger flex items-center justify-between w-full py-5 text-left text-white hover:text-gold-400 transition-colors duration-200 font-medium"
                aria-expanded="false"
                data-index={i}
              >
                <span class="pr-6">{faq.q}</span>
                <span class="faq-icon flex-shrink-0 w-6 h-6 rounded-full border border-white/10 flex items-center justify-center">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
                  </svg>
                </span>
              </button>
              <div class="faq-content">
                <div class="overflow-hidden">
                  <div class="pb-6 text-slate-400 text-sm leading-relaxed pr-10">
                    <p>{faq.a}</p>
                    {faq.link && (
                      <a
                        href={faq.link.href}
                        class="inline-flex items-center gap-1.5 text-gold-400 hover:text-gold-300 transition-colors mt-3 text-sm"
                      >
                        {faq.link.label}
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                        </svg>
                      </a>
                    )}
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Still need help -->
      <div class="reveal glass-card rounded-3xl p-10 md:p-14 text-center relative overflow-hidden">
        <div class="pointer-events-none absolute inset-0 flex items-center justify-center">
          <div class="w-48 h-48 rounded-full bg-gold-500/[0.06] blur-[60px]"></div>
        </div>
        <div class="relative z-10">
          <h2 class="font-serif text-2xl md:text-3xl font-bold text-white mb-3">Still need help?</h2>
          <p class="text-slate-400 mb-8">Can't find what you're looking for? Email us — we reply within 48 hours.</p>
          <a href="mailto:support@hsrutility.com" class="btn-gold mb-6">
            Contact Support
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </a>
          <p class="text-slate-500 text-sm mt-6">
            <span class="text-slate-400 font-medium">support@hsrutility.com</span>
          </p>
        </div>
      </div>

    </div>
  </main>

  <Footer />
</Layout>

<script>
  function setupFAQ() {
    const triggers = document.querySelectorAll<HTMLButtonElement>('.faq-trigger');

    triggers.forEach(trigger => {
      // Remove any pre-existing listener by cloning
      const fresh = trigger.cloneNode(true) as HTMLButtonElement;
      trigger.parentNode?.replaceChild(fresh, trigger);

      fresh.addEventListener('click', () => {
        const content = fresh.nextElementSibling as HTMLElement | null;
        const isOpen = fresh.classList.contains('open');

        // Close all others
        document.querySelectorAll('.faq-trigger').forEach(t => {
          t.classList.remove('open');
          t.setAttribute('aria-expanded', 'false');
        });
        document.querySelectorAll('.faq-content').forEach(c => c.classList.remove('open'));

        // Toggle this one
        if (!isOpen) {
          fresh.classList.add('open');
          fresh.setAttribute('aria-expanded', 'true');
          content?.classList.add('open');
        }
      });
    });
  }

  setupFAQ();
  document.addEventListener('astro:after-swap', setupFAQ);
</script>
