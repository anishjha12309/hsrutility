---
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Apps', href: '/#apps' },
  { label: 'Support', href: '/support' },
];
---

<header class="fixed top-4 left-0 right-0 z-50 px-4">
  <nav id="main-nav" class="glass-nav rounded-full max-w-4xl mx-auto flex items-center justify-between px-5 py-3">

    <!-- Brand -->
    <a href="/" class="flex items-center gap-2.5 flex-shrink-0">
      <div class="w-8 h-8 rounded-lg bg-gold-500 flex items-center justify-center flex-shrink-0">
        <span class="font-serif font-bold text-navy-900 text-sm leading-none">H</span>
      </div>
      <span class="text-white font-semibold text-sm hidden sm:block">HSR Utility</span>
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="text-slate-300 hover:text-white text-sm px-4 py-2 rounded-full hover:bg-white/5 transition-all duration-200"
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Right side -->
    <div class="flex items-center gap-3">
      <a
        href="/privacy"
        class="hidden md:block border border-gold-500/40 text-gold-400 text-sm px-5 py-2 rounded-full hover:bg-gold-500/10 hover:border-gold-500/60 transition-all duration-200"
      >
        Privacy
      </a>

      <!-- Mobile hamburger -->
      <button
        id="menu-btn"
        class="md:hidden w-8 h-8 flex items-center justify-center rounded-full hover:bg-white/10 transition-colors"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
      >
        <svg id="icon-open" class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="icon-close" class="w-5 h-5 text-white hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile dropdown -->
  <div id="mobile-menu" class="hidden md:hidden mt-2 max-w-4xl mx-auto">
    <div class="glass-card rounded-2xl p-3 space-y-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="block text-slate-300 hover:text-white text-sm px-4 py-3 rounded-xl hover:bg-white/5 transition-all duration-200"
        >
          {link.label}
        </a>
      ))}
      <a
        href="/privacy"
        class="block text-gold-400 text-sm px-4 py-3 rounded-xl hover:bg-gold-500/10 transition-all duration-200"
      >
        Privacy
      </a>
    </div>
  </div>
</header>

<script>
  // ── Mobile menu toggle ──
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    btn?.setAttribute('aria-expanded', String(!isOpen));
  });

  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
    });
  });

  // ── Navbar darkens on scroll ──
  const nav = document.getElementById('main-nav');

  function updateNavOnScroll() {
    nav?.classList.toggle('scrolled', window.scrollY > 24);
  }

  window.addEventListener('scroll', updateNavOnScroll, { passive: true });
  // Re-check after View Transition swaps (page may load mid-scroll)
  document.addEventListener('astro:after-swap', updateNavOnScroll);
  updateNavOnScroll();
</script>
