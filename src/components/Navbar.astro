---
const pathname = Astro.url.pathname;

const navLinks = [
  { label: 'Home', href: '/', active: pathname === '/' },
  { label: 'Apps', href: '/#apps', active: pathname === '/' },
  { label: 'Support', href: '/support', active: pathname.startsWith('/support') },
];

const privacyActive = pathname.startsWith('/privacy');
---

<header class="fixed top-4 left-0 right-0 z-50 px-4">
  <nav id="main-nav" class="glass-nav rounded-full max-w-4xl mx-auto flex items-center justify-between px-5 py-3">

    <!-- Brand -->
    <a href="/" class="flex items-center gap-2.5 flex-shrink-0">
      <div class="w-8 h-8 rounded-lg bg-gold-500 flex items-center justify-center flex-shrink-0">
        <span class="font-serif font-bold text-navy-900 text-sm leading-none">H</span>
      </div>
      <span class="text-white font-semibold text-sm hidden sm:block">HSR Utility</span>
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`text-sm px-4 py-2 rounded-full transition-all duration-200 ${link.active ? 'text-white bg-white/8' : 'text-slate-300 hover:text-white hover:bg-white/5'}`}
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Right side -->
    <div class="flex items-center gap-3">
      <a
        href="/privacy"
        class={`hidden md:block border text-gold-400 text-sm px-5 py-2 rounded-full transition-all duration-200 ${privacyActive ? 'border-gold-500/60 bg-gold-500/10' : 'border-gold-500/40 hover:bg-gold-500/10 hover:border-gold-500/60'}`}
      >
        Privacy
      </a>

      <!-- Mobile hamburger — 44px touch target -->
      <button
        id="menu-btn"
        class="md:hidden w-11 h-11 flex items-center justify-center rounded-full hover:bg-white/10 transition-colors"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
      >
        <svg id="icon-open" class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="icon-close" class="w-5 h-5 text-white hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile dropdown — animated slide-down -->
  <div id="mobile-menu" class="mt-2 max-w-4xl mx-auto">
    <div class="overflow-hidden">
      <div class="glass-card rounded-2xl p-3 space-y-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`block text-sm px-4 py-3 rounded-xl transition-all duration-200 ${link.active ? 'text-white bg-white/8' : 'text-slate-300 hover:text-white hover:bg-white/5'}`}
          >
            {link.label}
          </a>
        ))}
        <a
          href="/privacy"
          class={`block text-gold-400 text-sm px-4 py-3 rounded-xl transition-all duration-200 ${privacyActive ? 'bg-gold-500/10' : 'hover:bg-gold-500/10'}`}
        >
          Privacy
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  #mobile-menu {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transition:
      grid-template-rows 0.3s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.22s ease;
    pointer-events: none;
  }

  #mobile-menu.open {
    grid-template-rows: 1fr;
    opacity: 1;
    pointer-events: auto;
  }

  @media (min-width: 768px) {
    #mobile-menu { display: none; }
  }
</style>

<script>
  function setupNavMenu() {
    const btn = document.getElementById('menu-btn');
    const menu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('icon-open');
    const iconClose = document.getElementById('icon-close');

    if (!btn || !menu) return;

    // Clone button to remove stale listeners from prior navigations
    const freshBtn = btn.cloneNode(true) as HTMLButtonElement;
    btn.parentNode?.replaceChild(freshBtn, btn);

    freshBtn.addEventListener('click', () => {
      const isOpen = menu.classList.contains('open');
      menu.classList.toggle('open', !isOpen);
      iconOpen?.classList.toggle('hidden', !isOpen);
      iconClose?.classList.toggle('hidden', isOpen);
      freshBtn.setAttribute('aria-expanded', String(!isOpen));
    });

    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        menu.classList.remove('open');
        iconOpen?.classList.remove('hidden');
        iconClose?.classList.add('hidden');
        freshBtn.setAttribute('aria-expanded', 'false');
      });
    });

    // ── Navbar darkens on scroll ──
    const nav = document.getElementById('main-nav');
    function updateNavOnScroll() {
      nav?.classList.toggle('scrolled', window.scrollY > 24);
    }
    window.addEventListener('scroll', updateNavOnScroll, { passive: true });
    updateNavOnScroll();
  }

  setupNavMenu();
  document.addEventListener('astro:after-swap', setupNavMenu);
</script>
